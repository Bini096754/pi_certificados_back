{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "types": ["bun"],
    "moduleResolution": "node",
    "rootDir": "./",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types",
      "./src/@types"
    ]
  },
  "include": [
    "src/**/*"
  ]
}
